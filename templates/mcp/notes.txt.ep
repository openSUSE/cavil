%     }
## Note #<%= $note->{id} %> by <%== $note->{author_login} %> (<%= Mojo::Date->new($note->{created_epoch})->to_datetime %>) <%== $relevance %><%== $note->{ai_assisted} ? ' [AI-assisted]' : '' %><%== $note->{lawyer_only} ? ' [lawyer-only]' : '' %><%== @{$note->{tags}} ? ' [tags: ' . join(', ', @{$note->{tags}}) . ']' : '' %>

%== $body

