% my $page_title = $match->{id} ? "Edit license pattern" : "New license pattern";
% layout 'default', title => $page_title;

<h3 class="mt-3"><%= $page_title %></h3>

<div id="edit-pattern" data-pattern="<%= Mojo::JSON::encode_json($match) %>"></div>

% content_for ready_function => begin
  cavil.setupEditPattern(JSON.parse(document.getElementById('edit-pattern').dataset.pattern));
% end
